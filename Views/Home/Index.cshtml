<div class="container mt-5">
    <div class="card shadow p-4">
        <h3 class="text-center mb-4">Ads.txt Partner Kontrolü</h3>
        
        <form asp-controller="Home" asp-action="StartScan" method="post" enctype="multipart/form-data">
            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label">Web Sitesi Listesi (.txt)</label>
                    <input type="file" name="file" class="form-control" accept=".txt" required />
                </div>
                
                <div class="col-md-4">
                    <label class="form-label">Aranacak Partner</label>
                    <input type="text" name="selectedPartner" class="form-control" placeholder="Örn: admatic.com.tr, adtarget.com.tr, pixad.com.tr" required>
                </div>
                
                <div class="col-md-2 d-flex align-items-end">
                    <button type="submit" class="btn btn-primary w-100">Sorgula</button>
                </div>
            </div>
        </form>
    </div>
</div>